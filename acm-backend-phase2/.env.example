# MongoDB Atlas connection string (see README for how to get this)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/acm-website

# Any long random string - used to sign login tokens. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# Port the server runs on locally
PORT=5000

# Comma-separated list of frontend URLs allowed to call this API
CORS_ORIGINS=http://localhost:5173,https://your-site.vercel.app

# Used only once, by `npm run seed:admin`, to create your first admin login
SEED_ADMIN_NAME=Shardul Kulkarni
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-password
